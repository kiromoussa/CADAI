# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Required for /api/analyze (bypasses RLS for analyses + violations writes)

# Anthropic
ANTHROPIC_API_KEY=

# Voyage AI (code embeddings)
VOYAGE_API_KEY=

# Autodesk Platform Services
# Register EVERY callback URL you use in https://aps.autodesk.com/myapps (exact match).
# If Next.js falls back to port 3001, add http://localhost:3001/api/aps/auth too.
APS_CLIENT_ID=
APS_CLIENT_SECRET=
APS_CALLBACK_URL=http://localhost:3000/api/aps/auth

# App base URL (used for redirects after OAuth). Match the port shown by `npm run dev`.
NEXT_PUBLIC_APP_URL=http://localhost:3000
